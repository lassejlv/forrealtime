{
  "name": "forrealtime",
  "type": "module",
  "version": "0.1.5",
  "description": "Framework-agnostic realtime primitives powered by Redis Streams.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "url": "http://github.com/lassejlv/forrealtime.git",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./adapters/ioredis": {
      "types": "./dist/adapters/ioredis.d.ts",
      "import": "./dist/adapters/ioredis.js",
      "require": "./dist/adapters/ioredis.cjs"
    },
    "./adapters/bun": {
      "types": "./dist/adapters/bun.d.ts",
      "import": "./dist/adapters/bun.js",
      "require": "./dist/adapters/bun.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "ioredis": "^5.8.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "zod": "^4.1.11"
  }
}
